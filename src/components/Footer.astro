---
const navLinks = [
  { label: 'The Experience', href: '/experience' },
  { label: 'About', href: '/about' },
  { label: 'FAQ', href: '/faq' },
  { label: 'Book', href: '/book' },
];

const legalLinks = [
  { label: 'Privacy Policy', href: '/privacy' },
  { label: 'Terms', href: '/terms' },
];

const year = new Date().getFullYear();
---

<footer class="bg-brand-surface pt-section pb-3xl">
  <div class="mx-auto max-w-[90rem] px-lg md:px-2xl">
    <!-- Logo -->
    <div class="mb-4xl text-center">
      <a href="/" aria-label="Calaire — Home">
        <span class="block font-heading text-[2rem] font-medium uppercase leading-none tracking-[0.15em] md:text-[2.5rem]">
          Calaire
        </span>
        <span class="block font-body text-[0.65rem] font-light uppercase leading-none tracking-[0.3em] mt-[0.15rem] text-brand-muted md:text-[0.75rem]">
          Wellness Club
        </span>
      </a>
    </div>

    <!-- Navigation -->
    <nav class="mb-3xl flex flex-wrap items-center justify-center gap-xl md:gap-2xl" aria-label="Footer navigation">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="font-body text-small font-light uppercase tracking-[0.15em] text-brand-muted transition-colors hover:text-brand-primary"
          style={`transition-duration: var(--duration-fast);`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Divider -->
    <div class="mx-auto mb-xl h-px max-w-[20rem] bg-brand-border"></div>

    <!-- Contact -->
    <div class="mb-lg text-center">
      <a
        href="mailto:hello@calaire.club"
        class="font-body text-body font-light text-brand-muted transition-colors hover:text-brand-primary"
        style={`transition-duration: var(--duration-fast);`}
      >
        hello@calaire.club
      </a>
      <!-- PLACEHOLDER: Add phone number when available -->
    </div>

    <!-- Social Links -->
    <div class="mb-lg flex items-center justify-center gap-xl">
      <!-- PLACEHOLDER: Replace with real social links and icons when available -->
      <span class="font-body text-small font-light uppercase tracking-[0.15em] text-brand-muted">Instagram</span>
    </div>

    <!-- Location -->
    <p class="mx-auto mb-xl text-center font-body text-small font-light tracking-[0.1em] text-brand-muted">
      Austin, Texas
    </p>

    <!-- Legal & Copyright -->
    <div class="flex flex-col items-center gap-sm text-center">
      <div class="flex flex-wrap items-center justify-center gap-lg">
        {legalLinks.map((link) => (
          <a
            href={link.href}
            class="font-body text-caption font-light text-brand-muted transition-colors hover:text-brand-primary"
            style={`transition-duration: var(--duration-fast);`}
          >
            {link.label}
          </a>
        ))}
      </div>
      <p class="font-body text-caption font-light text-brand-muted">
        &copy; {year} Calaire Wellness Club
      </p>
    </div>
  </div>
</footer>
