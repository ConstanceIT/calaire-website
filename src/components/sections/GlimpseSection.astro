---
/**
 * Section 4: A Glimpse of the Day
 * Vertical scroll sequence with three time blocks, alternating image/text layout.
 * Scroll-reveal via Intersection Observer, CSS scroll-driven parallax on images.
 */

const timeBlocks = [
  {
    time: '10am',
    label: 'Morning',
    text: 'Arrive to a quiet room. Set your things down. The day begins with guided movement — yoga or Pilates — to settle you into your body and out of your head.',
    imageLabel: 'Morning — Small group yoga, peaceful light',
    imageAlt: 'Early morning yoga in a sunlit studio with women on mats spaced comfortably',
    imagePosition: 'left',
  },
  {
    time: '2pm',
    label: 'Afternoon',
    text: "After a long lunch with no agenda, the afternoon is yours. Massage. Acupuncture. Meditation. Time to do nothing at all. There's space for whatever you need.",
    imageLabel: 'Afternoon — Woman on massage table, eyes closed',
    imageAlt: 'A woman resting on a massage table with warm ambient lighting',
    imagePosition: 'right',
  },
  {
    time: '7pm',
    label: 'Evening',
    text: "The day closes with dinner — a meal designed for conversation, not performance. You'll sit with women who spent the day alongside you. No one has to explain themselves.",
    imageLabel: 'Evening — Candlelit communal dinner',
    imageAlt: 'Evening dinner with women at a candlelit communal table',
    imagePosition: 'left',
  },
];
---

<section aria-label="A glimpse of the day" class="bg-brand-primary py-section text-brand-white">
  <div class="mx-auto max-w-[90rem] px-lg md:px-2xl">
    <!-- Section Heading -->
    <h2 data-reveal class="mb-5xl max-w-[22ch] font-heading text-h1 font-medium uppercase leading-[0.95] tracking-[0.02em]">
      From sunrise yoga to candlelit dinner.
    </h2>

    <!-- Time Blocks -->
    <div class="space-y-section">
      {timeBlocks.map((block) => (
        <div
          class="glimpse-block grid grid-cols-1 items-center gap-2xl lg:grid-cols-2 lg:gap-4xl"
        >
          <!-- IMAGE NEEDED: Replace this placeholder div with an <img> tag. -->
          <div data-reveal class={`glimpse-image overflow-hidden ${block.imagePosition === 'right' ? 'lg:order-2' : 'lg:order-1'}`}>
            <div class="glimpse-image-parallax aspect-[3/2] border border-brand-sage-dark bg-brand-sage" role="img" aria-label={block.imageAlt}>
              <div class="flex h-full w-full items-center justify-center p-lg">
                <span class="text-center font-body text-small font-light text-brand-sage-dark">{block.imageLabel}</span>
              </div>
            </div>
          </div>

          <!-- Text Side -->
          <div data-reveal class={`glimpse-text ${block.imagePosition === 'right' ? 'lg:order-1' : 'lg:order-2'}`}>
            <span class="glimpse-time block font-heading text-h1 font-medium leading-none text-brand-sage">
              {block.time}
            </span>
            <p class="mt-xl max-w-[36ch] font-body text-body-lg font-light leading-relaxed text-brand-white">
              {block.text}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div data-reveal class="mt-5xl text-center">
      <a
        href="/experience"
        class="inline-flex items-center gap-sm font-body text-body font-light uppercase tracking-[0.15em] text-brand-white transition-opacity hover:opacity-60"
        style={`transition-duration: var(--duration-fast);`}
      >
        See the full experience
        <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </div>
</section>

<style>
  /* CSS scroll-driven parallax for glimpse images */
  @supports (animation-timeline: view()) {
    .glimpse-image-parallax {
      animation: glimpse-parallax linear both;
      animation-timeline: view();
      animation-range: entry 0% exit 100%;
    }

    @keyframes glimpse-parallax {
      from {
        transform: translateY(-3%);
      }
      to {
        transform: translateY(3%);
      }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .glimpse-image-parallax {
      animation: none;
    }
  }
</style>
