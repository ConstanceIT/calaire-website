---
/**
 * Section 8: Closing CTA
 * Full-width section with background color shift on scroll.
 * CSS scroll-driven background transition.
 */
---

<section aria-label="Reserve your place" class="closing-cta relative overflow-hidden py-spacing-section">
  <div class="mx-auto max-w-[60rem] px-spacing-lg text-center md:px-spacing-2xl">
    <h2 class="reveal-on-scroll mx-auto max-w-[20ch] font-heading text-h1 font-medium uppercase leading-[0.95] tracking-[0.02em] text-brand-primary">
      You've been managing everything. Let someone manage this.
    </h2>

    <p class="reveal-on-scroll-delayed mx-auto mt-spacing-2xl max-w-[36ch] font-body text-body-lg font-light leading-relaxed text-brand-primary">
      Thirty guests. One Saturday. Everything included.
    </p>

    <div class="reveal-on-scroll-delayed mt-spacing-3xl flex flex-col items-center gap-spacing-lg">
      <a
        href="/book"
        class="inline-flex items-center justify-center bg-brand-primary px-spacing-3xl py-spacing-md font-body text-body font-light uppercase tracking-[0.15em] text-brand-white transition-colors hover:bg-brand-primary-hover"
        style={`transition-duration: var(--duration-normal);`}
      >
        Reserve Your Place
      </a>
      <a
        href="mailto:hello@calaire.club"
        class="inline-flex items-center gap-spacing-sm font-body text-body font-light uppercase tracking-[0.15em] text-brand-primary transition-opacity hover:opacity-60"
        style={`transition-duration: var(--duration-fast);`}
      >
        Have questions? Get in touch
      </a>
    </div>
  </div>
</section>

<style>
  .closing-cta {
    background-color: var(--color-brand-background);
  }

  /* Smooth background color transition on scroll entry */
  @supports (animation-timeline: view()) {
    .closing-cta {
      animation: closing-bg-shift linear both;
      animation-timeline: view();
      animation-range: entry 0% entry 40%;
    }

    @keyframes closing-bg-shift {
      from {
        background-color: var(--color-brand-background);
      }
      to {
        background-color: var(--color-brand-sage);
      }
    }
  }

  @supports not (animation-timeline: view()) {
    .closing-cta {
      background-color: var(--color-brand-sage);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .closing-cta {
      animation: none;
      background-color: var(--color-brand-sage);
    }
  }
</style>
