---
/**
 * Section 1: Hero
 * Full-bleed video background, centered content, staggered GSAP SplitText animation.
 */
---

<section aria-label="Welcome" class="relative flex min-h-screen items-center justify-center overflow-hidden">
  <!-- Video Background (hidden on mobile) -->
  <video
    class="absolute inset-0 z-0 hidden h-full w-full object-cover md:block"
    autoplay
    muted
    loop
    playsinline
    preload="auto"
  >
    <source src="/hero-video-compressed.mp4" type="video/mp4" />
  </video>

  <!-- Fallback Image (mobile only) -->
  <img
    src="/hero-fallback.jpg"
    alt=""
    aria-hidden="true"
    class="absolute inset-0 z-0 h-full w-full object-cover md:hidden"
  />

  <!-- Dark overlay for text contrast -->
  <div class="absolute inset-0 z-[1] bg-black/40"></div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-[85rem] px-lg pb-20 text-center text-white md:px-2xl">
    <h1
      id="hero-headline"
      class="gsap-pre-hide mx-auto max-w-[20ch] font-heading text-display font-medium uppercase leading-[1] tracking-[0.03em]"
    >
      A full day designed around one idea: rest.
    </h1>

    <p
      id="hero-subheadline"
      class="mx-auto mt-xl max-w-[50ch] font-body text-body-lg font-light leading-relaxed opacity-0"
    >
      Curated wellness retreats for women in Austin. Massage, movement, meditation, and meals — all included, all handled. Your only job is to show up.
    </p>

    <div id="hero-ctas" class="mt-2xl flex flex-col items-center justify-center gap-md opacity-0 sm:flex-row sm:gap-lg">
      <a
        href="/book"
        class="inline-flex items-center justify-center bg-white/20 px-xl py-md font-body text-body font-light uppercase tracking-[0.15em] text-white backdrop-blur-sm border border-white/30 transition-colors hover:bg-white/30 sm:px-3xl"
        style={`transition-duration: var(--duration-normal);`}
      >
        Reserve Your Place
      </a>
      <a
        href="/experience"
        class="inline-flex items-center justify-center border border-white/60 px-xl py-md font-body text-body font-light uppercase tracking-[0.15em] text-white transition-colors hover:bg-white/10 sm:px-3xl"
        style={`transition-duration: var(--duration-normal);`}
      >
        See What's Included
      </a>
    </div>
  </div>
</section>

<script>
  function initHeroAnimation() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const headline = document.getElementById('hero-headline');
      const sub = document.getElementById('hero-subheadline');
      const ctas = document.getElementById('hero-ctas');
      if (headline) headline.style.opacity = '1';
      if (sub) sub.style.opacity = '1';
      if (ctas) ctas.style.opacity = '1';
      return;
    }

    import('../../scripts/gsap-setup').then(({ gsap, SplitText }) => {
      const headline = document.getElementById('hero-headline');
      const sub = document.getElementById('hero-subheadline');
      const ctas = document.getElementById('hero-ctas');

      if (!headline) return;

      const split = new SplitText(headline, { type: 'words' });

      const tl = gsap.timeline({ defaults: { ease: 'power4.out' } });

      tl.from(split.words, {
        opacity: 0,
        y: 20,
        duration: 0.8,
        stagger: 0.08,
      });

      if (sub) {
        tl.to(sub, {
          opacity: 1,
          duration: 0.6,
          ease: 'power2.out',
        }, '-=0.3');
      }

      if (ctas) {
        tl.to(ctas, {
          opacity: 1,
          duration: 0.5,
          ease: 'power2.out',
        }, '-=0.2');
      }
    });
  }

  initHeroAnimation();
  document.addEventListener('astro:after-swap', initHeroAnimation);
</script>
