---
/**
 * Section 1: Hero
 * Full-bleed video background, centered content, CSS keyframe entrance animation.
 */
---

<section aria-label="Welcome" class="relative flex min-h-screen items-center justify-center overflow-hidden">
  <!-- Video Background -->
  <video
    class="absolute inset-0 z-0 h-full w-full object-cover"
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    poster="/hero-fallback.jpg"
  >
    <source src="/hero-video-compressed.mp4" type="video/mp4" />
  </video>

  <!-- Dark overlay for text contrast -->
  <div class="absolute inset-0 z-[1] bg-black/50"></div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-[85rem] px-lg pb-20 pt-32 text-center text-white md:px-2xl">
    <h1 class="hero-animate mx-auto font-heading text-display font-medium uppercase leading-[1.05] tracking-[0.03em]">
      The retreat you've been craving,<br />
      <span class="inline-block">in one day.</span>
    </h1>

    <p class="hero-animate hero-delay-1 mx-auto mt-xl max-w-[50ch] font-body text-body-lg font-light leading-relaxed">
      Curated wellness retreats for women in Austin.
    </p>

    <p class="hero-animate hero-delay-1 mx-auto mt-sm max-w-[50ch] font-body text-body-lg font-light leading-relaxed">
      Movement, massage, meditation, and meals. All included, all tailored to you.
    </p>

    <div class="hero-animate hero-delay-2 mt-2xl flex flex-col items-center justify-center gap-md pb-md sm:flex-row sm:gap-lg">
      <a
        href="/book"
        class="inline-flex items-center justify-center bg-white/20 px-xl py-md font-body text-body font-light uppercase tracking-[0.15em] text-white backdrop-blur-sm border border-white/30 transition-colors hover:bg-white/30 sm:px-3xl"
        style="transition-duration: var(--duration-normal);"
      >
        Reserve Your Place
      </a>
      <a
        href="/experience"
        class="inline-flex items-center justify-center border border-white px-xl py-md font-body text-body font-light uppercase tracking-[0.15em] text-white transition-colors hover:bg-white/10 sm:px-3xl"
        style="transition-duration: var(--duration-normal);"
      >
        See What's Included
      </a>
    </div>
  </div>
</section>

<style>
  /* Hero entrance animation — pure CSS, no JS dependency */
  @keyframes hero-fade-up {
    from {
      opacity: 0;
      transform: translateY(1.5rem);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  .hero-animate {
    opacity: 0;
    animation: hero-fade-up 0.8s ease-out forwards;
  }

  .hero-delay-1 {
    animation-delay: 0.3s;
  }

  .hero-delay-2 {
    animation-delay: 0.5s;
  }

  /* Reduced motion: show everything immediately, no animation */
  @media (prefers-reduced-motion: reduce) {
    .hero-animate {
      opacity: 1;
      animation: none;
    }
  }
</style>
