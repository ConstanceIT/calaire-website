---
const navLinks = [
  { label: 'The Experience', href: '/experience' },
  { label: 'About', href: '/about' },
  { label: 'FAQ', href: '/faq' },
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-40 transition-colors"
  style={`transition-duration: var(--duration-normal); transition-timing-function: var(--ease-out-quart);`}
  data-scrolled="false"
  data-header-theme="light"
>
  <div class="mx-auto flex max-w-[90rem] items-center justify-between px-lg py-md md:px-2xl md:py-lg">
    <!-- Logo -->
    <a href="/" class="group text-center" aria-label="Calaire — Home">
      <span class="block font-heading text-[1.5rem] font-medium uppercase leading-none tracking-[0.15em] md:text-[1.75rem]">
        Calaire
      </span>
      <span class="block font-body text-[0.6rem] font-light uppercase leading-none tracking-[0.3em] mt-[0.15rem] md:text-[0.65rem] text-center">
        Wellness Club
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden items-center gap-2xl lg:flex" aria-label="Main navigation">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="font-body text-small font-light uppercase tracking-[0.15em] transition-opacity hover:opacity-60"
          style={`transition-duration: var(--duration-fast);`}
        >
          {link.label}
        </a>
      ))}
      <a
        href="/book"
        class="header-cta inline-flex items-center justify-center bg-brand-primary px-xl py-sm font-body text-small font-light uppercase tracking-[0.15em] text-brand-white transition-colors hover:bg-brand-primary-hover"
        style={`transition-duration: var(--duration-normal);`}
      >
        Reserve Your Place
      </a>
    </nav>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-toggle"
      class="flex min-h-[44px] min-w-[44px] flex-col items-center justify-center gap-[5px] p-sm lg:hidden"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="block h-[1px] w-6 bg-current transition-transform" style={`transition-duration: var(--duration-normal);`}></span>
      <span class="block h-[1px] w-4 bg-current transition-opacity" style={`transition-duration: var(--duration-normal);`}></span>
      <span class="block h-[1px] w-6 bg-current transition-transform" style={`transition-duration: var(--duration-normal);`}></span>
    </button>
  </div>
</header>

<!-- Mobile Menu — sibling of header, NOT inside it -->
<nav
  id="mobile-menu"
  class="fixed inset-0 z-30 flex flex-col items-center justify-center bg-brand-background opacity-0 pointer-events-none transition-opacity lg:hidden"
  style={`transition-duration: var(--duration-slow);`}
  aria-label="Mobile navigation"
  aria-hidden="true"
>
  <a href="/" class="mobile-menu-link font-heading text-h3 font-medium uppercase tracking-[0.1em] text-brand-primary">
    Home
  </a>
  {navLinks.map((link) => (
    <a
      href={link.href}
      class="mobile-menu-link mt-3xl font-heading text-h3 font-medium uppercase tracking-[0.1em] text-brand-primary"
    >
      {link.label}
    </a>
  ))}
  <a
    href="/book"
    class="mobile-menu-cta mt-3xl inline-flex items-center justify-center bg-brand-primary px-3xl py-md font-body text-body font-light uppercase tracking-[0.15em] text-brand-white"
  >
    Reserve Your Place
  </a>
</nav>

<style>
  /* Header background on scroll */
  #site-header[data-scrolled="true"] {
    background-color: oklch(from var(--color-brand-background) l c h / 0.95);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  /* Header light theme (over hero) */
  #site-header[data-header-theme="light"],
  #site-header[data-header-theme="light"] a,
  #site-header[data-header-theme="light"] span {
    color: #FFFFFF;
  }

  /* Header dark theme (scrolled past hero) */
  #site-header[data-header-theme="dark"],
  #site-header[data-header-theme="dark"] a:not(.header-cta),
  #site-header[data-header-theme="dark"] span {
    color: var(--color-brand-primary);
  }
</style>

<script>
  function initHeader() {
    const header = document.getElementById('site-header');
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (!header || !toggle || !menu) return;

    const lines = toggle.querySelectorAll('span');
    const menuLinks = menu.querySelectorAll('a');
    let isOpen = false;

    // Scroll-based header theme
    function updateHeader() {
      if (isOpen) return; // Don't change theme while menu is open
      const scrolled = window.scrollY > 80;
      header.dataset.scrolled = String(scrolled);
      header.dataset.headerTheme = scrolled ? 'dark' : 'light';
    }

    window.addEventListener('scroll', updateHeader, { passive: true });
    updateHeader();

    function openMenu() {
      isOpen = true;
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Close menu');
      menu.setAttribute('aria-hidden', 'false');
      menu.classList.remove('opacity-0', 'pointer-events-none');
      menu.classList.add('opacity-100', 'pointer-events-auto');

      // Hamburger to X
      lines[0].style.transform = 'rotate(45deg) translateY(3px)';
      lines[1].style.opacity = '0';
      lines[2].style.transform = 'rotate(-45deg) translateY(-3px)';

      // Header: dark theme + background so logo/X are visible on cream
      header.dataset.headerTheme = 'dark';
      header.dataset.scrolled = 'true';

      // Lock scroll
      document.documentElement.style.overflow = 'hidden';
    }

    function closeMenu() {
      isOpen = false;
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Open menu');
      menu.setAttribute('aria-hidden', 'true');
      menu.classList.add('opacity-0', 'pointer-events-none');
      menu.classList.remove('opacity-100', 'pointer-events-auto');

      // X back to hamburger
      lines[0].style.transform = '';
      lines[1].style.opacity = '';
      lines[2].style.transform = '';

      // Unlock scroll
      document.documentElement.style.overflow = '';

      // Restore header theme based on scroll position
      const scrolled = window.scrollY > 80;
      header.dataset.scrolled = String(scrolled);
      header.dataset.headerTheme = scrolled ? 'dark' : 'light';

      toggle.focus();
    }

    // Toggle
    toggle.addEventListener('click', () => {
      isOpen ? closeMenu() : openMenu();
    });

    // Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) closeMenu();
    });

    // Close on link click
    menuLinks.forEach((link) => {
      link.addEventListener('click', () => {
        if (isOpen) closeMenu();
      });
    });

    // Focus trap
    menu.addEventListener('keydown', (e) => {
      if (e.key !== 'Tab' || !isOpen || menuLinks.length === 0) return;
      const first = menuLinks[0];
      const last = menuLinks[menuLinks.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    });
  }

  initHeader();
  document.addEventListener('astro:after-swap', initHeader);
</script>
